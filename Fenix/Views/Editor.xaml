<UserControl x:Class="Fenix.Editor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             mc:Ignorable="d"
             d:DesignHeight="363.333" d:DesignWidth="577.334">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <!-- Save -->
            <Button Click="saveFileClick" ToolTip="Save (Ctrl+S)">
                <TextBlock Text="💾" FontSize="{StaticResource Th.FontLg}" VerticalAlignment="Center" />
            </Button>
            <Separator />
            <!-- Clipboard -->
            <Button Command="Cut"    ToolTip="Cut">    <TextBlock Text="✂️"  FontSize="{StaticResource Th.FontLg}" VerticalAlignment="Center" /></Button>
            <Button Command="Copy"   ToolTip="Copy">   <TextBlock Text="📋"  FontSize="{StaticResource Th.FontLg}" VerticalAlignment="Center" /></Button>
            <Button Command="Paste"  ToolTip="Paste">  <TextBlock Text="📌"  FontSize="{StaticResource Th.FontLg}" VerticalAlignment="Center" /></Button>
            <Button Command="Delete" ToolTip="Delete"> <TextBlock Text="🗑️" FontSize="{StaticResource Th.FontLg}" VerticalAlignment="Center" /></Button>
            <Separator />
            <!-- History -->
            <Button Command="Undo" ToolTip="Undo"><TextBlock Text="↩️" FontSize="{StaticResource Th.FontLg}" VerticalAlignment="Center" /></Button>
            <Button Command="Redo" ToolTip="Redo"><TextBlock Text="↪️" FontSize="{StaticResource Th.FontLg}" VerticalAlignment="Center" /></Button>
            <Separator />
            <!-- Search -->
            <Button Click="Button_FindClick"    ToolTip="Find (Ctrl+F)">             <TextBlock Text="🔍" FontSize="{StaticResource Th.FontLg}" VerticalAlignment="Center" /></Button>
            <Button Click="Button_ReplaceClick" ToolTip="Find &amp; Replace (Ctrl+H)"><TextBlock Text="🔄" FontSize="{StaticResource Th.FontLg}" VerticalAlignment="Center" /></Button>
            <Separator />
            <!-- View toggles -->
            <ToggleButton IsChecked="{Binding ElementName=textEditor, Path=WordWrap,             Mode=TwoWay}" ToolTip="Word Wrap">
                <TextBlock Text="↵" FontSize="{StaticResource Th.FontLg}" VerticalAlignment="Center" />
            </ToggleButton>
            <ToggleButton IsChecked="{Binding ElementName=textEditor, Path=ShowLineNumbers,      Mode=TwoWay}" ToolTip="Line Numbers">
                <TextBlock Text="#" FontSize="{StaticResource Th.FontMd}" VerticalAlignment="Center" />
            </ToggleButton>
            <ToggleButton IsChecked="{Binding ElementName=textEditor, Path=Options.ShowEndOfLine, Mode=TwoWay}" ToolTip="Show End of Line">
                <TextBlock Text="¶" FontSize="{StaticResource Th.FontLg}" VerticalAlignment="Center" />
            </ToggleButton>
            <ToggleButton x:Name="btnShowCatalog" ToolTip="Script API Catalog (F2)" Click="BtnCatalog_Click">
                <TextBlock Text="📖" FontSize="{StaticResource Th.FontLg}" VerticalAlignment="Center" />
            </ToggleButton>
            <Separator />
            <!-- Syntax highlighting -->
            <ComboBox Name="highlightingComboBox"
                      Width="120"
                      SelectedItem="{Binding SyntaxHighlighting, ElementName=textEditor}"
                      ItemsSource="{Binding Source={x:Static avalonEdit:HighlightingManager.Instance}, Path=HighlightingDefinitions}"
                      SelectionChanged="HighlightingComboBox_SelectionChanged" />
            <Separator />
            <!-- Font size spinner -->
            <TextBlock Text="A" FontSize="{StaticResource Th.FontXs}"  VerticalAlignment="Center" Margin="4,0,3,0"
                       Foreground="{DynamicResource Th.TextSecBrush}" />
            <Button Content="−" Width="22" Padding="0" ToolTip="Decrease font size" Click="FontSizeDec_Click" />
            <TextBlock x:Name="tbFontSize" Width="38" TextAlignment="Center"
                       VerticalAlignment="Center" FontSize="{StaticResource Th.FontSm}"
                       Foreground="{DynamicResource Th.TextBrush}" />
            <Button Content="+" Width="22" Padding="0" ToolTip="Increase font size" Click="FontSizeInc_Click" />
            <TextBlock Text="A" FontSize="16" VerticalAlignment="Center" Margin="3,0,4,0"
                       Foreground="{DynamicResource Th.TextSecBrush}" />
        </ToolBar>

        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource Th.Surface2Brush}"
                   BorderBrush="{DynamicResource Th.BorderBrush}"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="tbCaretInfo" Text="Ln 1  Col 1"
                           Foreground="{DynamicResource Th.TextSecBrush}" FontSize="{StaticResource Th.FontSm}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="tbEncoding" Text="UTF-8"
                           Foreground="{DynamicResource Th.TextSecBrush}" FontSize="{StaticResource Th.FontSm}" />
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ Inline Find/Replace Panel ═══ -->
        <Border x:Name="SearchPanel"
                DockPanel.Dock="Bottom"
                Visibility="Collapsed"
                Background="{DynamicResource Th.Surface2Brush}"
                BorderBrush="{DynamicResource Th.BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" x:Name="ReplaceRowDef" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Find row -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Find:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox x:Name="txtFind" Grid.Row="0" Grid.Column="1" Margin="0,2,6,2"
                         KeyDown="TxtFind_KeyDown" TextChanged="TxtFind_TextChanged" />
                <Button Grid.Row="0" Grid.Column="2" Content="▲" Width="26" Margin="0,2,2,2"
                        ToolTip="Previous (Shift+Enter)" Click="FindPrevClick" />
                <Button Grid.Row="0" Grid.Column="3" Content="▼" Width="26" Margin="0,2,2,2"
                        ToolTip="Next (Enter)" Click="FindNextClick" />
                <TextBlock x:Name="tbSearchStatus" Grid.Row="0" Grid.Column="4"
                           VerticalAlignment="Center" Margin="6,0"
                           Foreground="{DynamicResource Th.TextSecBrush}" FontSize="{StaticResource Th.FontSm}" />
                <Button Grid.Row="0" Grid.Column="6" Content="✕" Width="26" Margin="4,2,0,2"
                        ToolTip="Close (Escape)" Click="CloseSearch_Click" />

                <!-- Replace row -->
                <TextBlock x:Name="lblReplace" Grid.Row="1" Grid.Column="0" Text="Replace:"
                           VerticalAlignment="Center" Margin="0,0,6,0" Visibility="Collapsed" />
                <TextBox x:Name="txtReplace" Grid.Row="1" Grid.Column="1" Margin="0,2,6,2"
                         Visibility="Collapsed" KeyDown="TxtReplace_KeyDown" />
                <Button x:Name="btnReplace" Grid.Row="1" Grid.Column="2" Content="Replace"
                        Margin="0,2,2,2" Padding="6,0" Visibility="Collapsed" Click="ReplaceClick" />
                <Button x:Name="btnReplaceAll" Grid.Row="1" Grid.Column="3" Content="All"
                        Width="40" Margin="0,2,2,2" Visibility="Collapsed" Click="ReplaceAllClick" />

                <!-- Options row -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="6"
                            Orientation="Horizontal" Margin="0,4,0,0">
                    <CheckBox x:Name="cbCaseSensitive" Content="Aa" ToolTip="Match case" Margin="0,0,10,0" />
                    <CheckBox x:Name="cbWholeWord"     Content="\b" ToolTip="Match whole word" Margin="0,0,10,0" />
                    <CheckBox x:Name="cbRegex"         Content=".*" ToolTip="Regular expression" Margin="0,0,10,0" />
                    <CheckBox x:Name="cbSearchUp"      Content="↑"  ToolTip="Search up" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CatalogSplitterCol" Width="0" />
                <ColumnDefinition x:Name="CatalogCol" Width="0" />
            </Grid.ColumnDefinitions>

            <avalonEdit:TextEditor
                Name="textEditor"
                Grid.Column="0"
                FontFamily="Consolas"
                FontSize="10pt"
                SyntaxHighlighting="C#">
            </avalonEdit:TextEditor>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Columns"
                          Background="{DynamicResource Th.BorderBrush}" />

            <!-- ═══ Script API Catalog Panel ═══ -->
            <Border x:Name="CatalogBorder"
                    Grid.Column="2"
                    Background="{DynamicResource Th.Surface2Brush}"
                    BorderBrush="{DynamicResource Th.BorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="6,5,4,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="API Catalog"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Th.TextBrush}" />
                        <Button Grid.Column="1" Content="✕" Width="22" Height="22"
                                Padding="0" VerticalContentAlignment="Center"
                                HorizontalContentAlignment="Center"
                                ToolTip="Close catalog"
                                Click="BtnCloseCatalog_Click" />
                    </Grid>

                    <!-- Filter -->
                    <TextBox x:Name="txtCatalogFilter"
                             Grid.Row="1"
                             Margin="4,0,4,4"
                             ToolTip="Filter functions..."
                             TextChanged="CatalogFilter_TextChanged" />

                    <!-- Function TreeView -->
                    <TreeView x:Name="tvCatalog"
                              Grid.Row="2"
                              BorderThickness="0"
                              Background="Transparent"
                              MouseDoubleClick="tvCatalog_MouseDoubleClick"
                              SelectedItemChanged="tvCatalog_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Functions}">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           Margin="0,2" />
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Signature}"
                                                   FontFamily="Consolas"
                                                   FontSize="{StaticResource Th.FontSm}"
                                                   Margin="0,1"
                                                   ToolTip="{Binding Description}" />
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <!-- Description -->
                    <Border Grid.Row="3"
                            Padding="6,4"
                            BorderBrush="{DynamicResource Th.BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <TextBlock x:Name="tbCatalogDesc"
                                   Text="Select a function to see details."
                                   TextWrapping="Wrap"
                                   MaxHeight="60"
                                   FontSize="10"
                                   Foreground="{DynamicResource Th.TextSecBrush}" />
                    </Border>
                </Grid>
            </Border>

            <Grid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="CopyHtmlToClipboard" Click="MenuItem_Click" />
                </ContextMenu>
            </Grid.ContextMenu>
        </Grid>
    </DockPanel>
</UserControl>