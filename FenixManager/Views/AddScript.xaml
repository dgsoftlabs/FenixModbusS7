<Window x:Class="FenixWPF.AddScript"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FenixWPF"
        mc:Ignorable="d"
        Title="Add New Script" Height="190" Width="430" WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Image Width="26" Height="26" Margin="0,0,0,10" Source="pack://application:,,,/TreeImage/CsFile.ico" HorizontalAlignment="Left" />
            <Label FontWeight="SemiBold" Content="File name(s):" Padding="0,0,0,2" />
            <TextBox x:Name="TbNewFile" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button MinWidth="80" Content="OK" Margin="0,0,6,0" Click="Button_OK_Click" />
            <Button MinWidth="80" Content="Cancel" Click="Button_Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>