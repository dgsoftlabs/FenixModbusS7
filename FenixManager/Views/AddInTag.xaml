<Window  x:Class="FenixWPF.AddInTag"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:PrCon="clr-namespace:ProjectDataLib;assembly=ProjectDataLib"
         xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:FenixWPF"
        mc:Ignorable="d"
        Title="Add InTag" Height="460" Width="330" WindowStartupLocation="CenterScreen">
    <Window.Resources>

        <ObjectDataProvider x:Key="TypeDataProvider" MethodName="GetValues"  ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="PrCon:TypeData" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <local:ValueConv x:Key="ValueConv" />
    </Window.Resources>

    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button MinWidth="80" Margin="0,0,6,0" Content="OK" Click="Button_Ok_Click" />
            <Button MinWidth="80" Content="Cancel" Click="Button_Cancel_Click" />
        </StackPanel>

        <StackPanel>
            <Image Width="26" Height="26" Margin="0,0,0,10" Source="pack://application:,,,/TreeImage/IntTag.png" HorizontalAlignment="Left" />

            <TextBlock FontWeight="SemiBold" Text="Name" />
            <TextBox Text="{Binding tagName, Mode=TwoWay}" />

            <TextBlock FontWeight="SemiBold" Text="Data Type" />
            <ComboBox ItemsSource="{Binding Source={StaticResource TypeDataProvider}}"
                      SelectedItem="{Binding TypeData,Mode=TwoWay}" />

            <TextBlock FontWeight="SemiBold" Text="Initial Value" />
            <TextBox>
                <TextBox.Text>
                    <MultiBinding Converter="{StaticResource ValueConv}">
                        <Binding Path="value" />
                        <Binding RelativeSource="{RelativeSource FindAncestor, AncestorType=Window}" Path="DataContext" />
                    </MultiBinding>
                </TextBox.Text>
            </TextBox>

            <TextBlock FontWeight="SemiBold" Text="Description" />
            <TextBox Height="100" Text="{Binding describe , Mode=TwoWay}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" />
        </StackPanel>
    </DockPanel>
</Window>