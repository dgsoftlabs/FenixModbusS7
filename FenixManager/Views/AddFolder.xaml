<Window x:Class="FenixWPF.AddFolder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Folder"
        Height="220"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CheckBox x:Name="Ch1" Grid.Row="0" Content="Create new folder" IsChecked="True" Margin="0,0,0,10" />

        <TextBlock Grid.Row="1" Text="New folder name" Margin="0,0,0,4" />
        <TextBox x:Name="TbNewFile" Grid.Row="2" Margin="0,0,0,8" />

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Existing folder path" Margin="0,0,0,4" />
            <DockPanel Grid.Row="1">
                <Button Content="Browse..." Width="90" Click="Button_File_Click" DockPanel.Dock="Right" Margin="8,0,0,0" />
                <TextBox x:Name="TbAddFile" />
            </DockPanel>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="85" Margin="0,0,8,0" IsDefault="True" Click="Button_OK_Click" />
            <Button Content="Cancel" Width="85" IsCancel="True" Click="Button_Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
