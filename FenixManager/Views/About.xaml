<Window x:Class="FenixWPF.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FenixWPF"
        mc:Ignorable="d"
        Title="About" Height="240" Width="420" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Width="110" Height="110" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,14,0">
                <Image Width="90" Height="90" Source="pack://application:,,,/TreeImage/Fenix.ico" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <StackPanel VerticalAlignment="Center">
                <TextBlock FontWeight="Bold" FontSize="18" Margin="0,0,0,8" Text="Fenix" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontWeight="SemiBold" Margin="0,0,6,0" Text="Version:" />
                    <TextBlock Name="TbVer" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Button Grid.Row="1" Content="Close" MinWidth="90" HorizontalAlignment="Right" Click="Button_Click" />
    </Grid>
</Window>