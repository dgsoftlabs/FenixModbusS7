<Window x:Name="window" x:Class="FenixWPF.AddProject"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FenixWPF"
        mc:Ignorable="d"
        Title="Add Project" Height="420" Width="320" WindowStartupLocation="CenterOwner"
        Background="{StaticResource Th.SurfaceBrush}">

    <Grid Style="{StaticResource Th.DialogRootGrid}" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Image Style="{StaticResource Th.DialogHeaderIcon}" Source="pack://application:,,,/TreeImage/Project.png" />

            <TextBlock Text="Project Name *" Style="{StaticResource Th.DialogSectionTitle}" />
            <TextBox Text="{Binding projectName}" x:Name="tbPrName" />

            <TextBlock Text="Author" Style="{StaticResource Th.DialogSectionTitle}" />
            <TextBox Text="{Binding autor}" />

            <TextBlock Text="Company" Style="{StaticResource Th.DialogSectionTitle}" />
            <TextBox Text="{Binding company}" />

            <TextBlock Text="Description" Style="{StaticResource Th.DialogSectionTitle}" />
            <TextBox Text="{Binding describe}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Style="{StaticResource Th.DialogBottomActionsPanel}">
            <Button Content="Save" Style="{StaticResource Th.DialogBottomPrimaryActionButton}" Click="Button_Save_Click" IsEnabled="{Binding ElementName=tbPrName,Path=Text.Length}" />
            <Button Content="Close" Style="{StaticResource Th.DialogBottomActionButton}" Click="Button_Close_Click" />
        </StackPanel>
    </Grid>
</Window>