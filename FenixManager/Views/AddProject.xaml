<Window x:Name="window" x:Class="FenixWPF.AddProject"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FenixWPF"
        mc:Ignorable="d"
        Title="Add Project" Height="420" Width="320" WindowStartupLocation="CenterOwner">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Image Width="26" Height="26" Margin="0,0,0,10" Source="pack://application:,,,/TreeImage/Project.png" HorizontalAlignment="Left" />

            <TextBlock Text="Project Name *" FontWeight="SemiBold" />
            <TextBox Text="{Binding projectName}" x:Name="tbPrName" />

            <TextBlock Text="Author" FontWeight="SemiBold" />
            <TextBox Text="{Binding autor}" />

            <TextBlock Text="Company" FontWeight="SemiBold" />
            <TextBox Text="{Binding company}" />

            <TextBlock Text="Description" FontWeight="SemiBold" />
            <TextBox Text="{Binding describe}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Save" Click="Button_Save_Click" MinWidth="80" Margin="0,0,6,0" IsEnabled="{Binding ElementName=tbPrName,Path=Text.Length}" />
            <Button Content="Close" Click="Button_Close_Click" MinWidth="80" />
        </StackPanel>
    </Grid>
</Window>