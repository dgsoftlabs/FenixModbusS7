<Window  x:Class="FenixWPF.AddCusFile"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FenixWPF"
        mc:Ignorable="d"
        Title="Add File / Files" Height="260" Width="430" WindowStartupLocation="CenterScreen">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Image Width="26" Height="26" Margin="0,0,0,10" Source="pack://application:,,,/TreeImage/HtmlFile.ico" HorizontalAlignment="Left" />
            <RadioButton x:Name="Ch1" IsChecked="True" FontWeight="SemiBold" Content="Add New File(s)" />
            <TextBox x:Name="TbNewFile" IsEnabled="{Binding IsChecked, ElementName=Ch1}" />

            <RadioButton x:Name="Ch2" FontWeight="SemiBold" Content="Add Existing File(s)" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbAddFile" IsEnabled="{Binding IsChecked, ElementName=Ch2}" IsReadOnly="True" Margin="0,0,6,8" />
                <Button IsEnabled="{Binding IsChecked, ElementName=Ch2}" Content="Browse" Click="Button_File_Click" Grid.Column="1" MinWidth="80" />
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button MinWidth="80" Content="OK" Margin="0,0,6,0" Click="Button_OK_Click" />
            <Button MinWidth="80" Content="Cancel" Click="Button_Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>