<Window x:Class="FenixWPF.AddCusFile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add File"
        Height="220"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Th.SurfaceBrush}">
    <Grid Style="{StaticResource Th.DialogRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CheckBox x:Name="Ch1" Grid.Row="0" Content="Create new file(s)" IsChecked="True" Margin="0,0,0,10" />

        <TextBlock Grid.Row="1" Text="New file name(s) (separate with ';')" Style="{StaticResource Th.DialogLabel}" />
        <TextBox x:Name="TbNewFile" Grid.Row="2" Margin="0,0,0,8" />

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Existing file path(s) (separate with ';')" Style="{StaticResource Th.DialogLabel}" />
            <DockPanel Grid.Row="1">
                <Button Content="Browse..." Click="Button_File_Click" Width="90" DockPanel.Dock="Right" Margin="8,0,0,0" />
                <TextBox x:Name="TbAddFile" />
            </DockPanel>
        </Grid>

        <StackPanel Grid.Row="4" Style="{StaticResource Th.DialogBottomActionsPanel}" Margin="0,12,0,0">
            <Button Content="OK" IsDefault="True" Click="Button_OK_Click" Width="85" Margin="0,0,8,0" />
            <Button Content="Cancel" IsCancel="True" Click="Button_Cancel_Click" Width="85" />
        </StackPanel>
    </Grid>
</Window>
