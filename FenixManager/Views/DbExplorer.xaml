<UserControl x:Class="FenixWPF.DbExplorer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FenixWPF"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{StaticResource Th.SurfaceBrush}">

    <UserControl.Resources>
        <local:BooleanNegationConverter x:Key="BooleanNegationConverter" />
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="12" Background="{StaticResource Th.SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Filters" Padding="12,10">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" ItemHeight="30">
                <CheckBox x:Name="BlockTimeFiltersCheckBox" Content="Block Time Filters" VerticalAlignment="Center" Margin="0,0,20,0" />

                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <DatePicker x:Name="FromDateCtrl"
                            Width="160"
                            Margin="0,0,14,0"
                            SelectedDate="{Binding FromDate, Mode=TwoWay}"
                            IsEnabled="{Binding IsChecked, ElementName=BlockTimeFiltersCheckBox, Converter={StaticResource BooleanNegationConverter}}" />

                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <DatePicker x:Name="ToDateCtrl"
                            Width="160"
                            Margin="0,0,14,0"
                            SelectedDate="{Binding ToDate, Mode=TwoWay}"
                            IsEnabled="{Binding IsChecked, ElementName=BlockTimeFiltersCheckBox, Converter={StaticResource BooleanNegationConverter}}" />

                <TextBlock Text="Last:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox x:Name="TimeIntervalComboBox"
                          Width="100"
                          Margin="0,0,18,0"
                          ItemsSource="{Binding TimeIntervals}"
                          SelectedItem="{Binding SelectedInterval, Mode=TwoWay}"
                          IsEnabled="{Binding IsChecked, ElementName=BlockTimeFiltersCheckBox, Converter={StaticResource BooleanNegationConverter}}" />

                <TextBlock Text="Order:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox x:Name="OrderComboBox"
                          Width="160"
                          Margin="0,0,14,0"
                          ItemsSource="{Binding OrderOptions}"
                          SelectedItem="{Binding SelectedOrder, Mode=TwoWay}" />

                <Button Content="Refresh" MinWidth="100" Click="ResetButton_Click" />
            </WrapPanel>
        </GroupBox>

        <DataGrid x:Name="myDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  ItemsSource="{Binding YourDataCollection}"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  BorderBrush="{StaticResource Th.BorderBrush}"
                  BorderThickness="1"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource Th.BorderBrush}"
                  VerticalGridLinesBrush="{StaticResource Th.BorderBrush}"
                  Background="{StaticResource Th.SurfaceBrush}"
                  RowBackground="{StaticResource Th.SurfaceBrush}"
                  AlternatingRowBackground="{StaticResource Th.Surface2Brush}"
                  Foreground="{StaticResource Th.TextBrush}"
                  Margin="0,0,0,2"
                  RowHeight="30"
                  ColumnHeaderHeight="34">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource Th.Surface2Brush}" />
                    <Setter Property="Foreground" Value="{StaticResource Th.TextBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Th.BorderBrush}" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="Padding" Value="10,6" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="8,2" />
                    <Setter Property="Foreground" Value="{StaticResource Th.TextBrush}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Name" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="5,0,0,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Date" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Stamp, StringFormat={}{0:MM/dd/yyyy}}" Margin="5,0,0,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Time" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Stamp, StringFormat={}{0:HH:mm:ss.fff}}" Margin="5,0,0,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Value" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Value}" Margin="5,0,0,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <ProgressBar Grid.Row="3"
                     IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Height="4"
                     Margin="0,8,0,0" />
    </Grid>
</UserControl>