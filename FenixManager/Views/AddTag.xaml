<Window x:Class="FenixWPF.AddTag"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:PrCon="clr-namespace:ProjectDataLib;assembly=ProjectDataLib"
        xmlns:local="clr-namespace:FenixWPF"
        mc:Ignorable="d"
        Title="Add Tag" Height="530" Width="360"
                   WindowStartupLocation="CenterOwner"
                   Background="{StaticResource Th.SurfaceBrush}">

    <Window.Resources>

        <ObjectDataProvider x:Key="TypeDataProvider" MethodName="GetValues"  ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="PrCon:TypeData" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="BytesOrderProvider" MethodName="GetValues"  ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="PrCon:BytesOrder" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="14,14,14,0">
                <TextBlock Style="{StaticResource Th.DialogSectionTitle}" Margin="0,0,0,2">Add Range</TextBlock>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10*" />
                    </Grid.ColumnDefinitions>

                    <CheckBox IsChecked="{Binding RangeAct}" Name="chbAddRange" Margin="0,5,0,0" />
                    <TextBox
                                    Grid.Column="1"
                                    Name="tbRangeCount"
                                    Text="{Binding Range, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    IsEnabled="{Binding ElementName=chbAddRange,Path=IsChecked}" />
                </Grid>

                <TextBlock Style="{StaticResource Th.DialogSectionTitle}" Margin="0,0,0,2">Tag Name*</TextBlock>
                <TextBox Name="tbName">
                    <TextBox.Text>
                        <Binding Path="TagName" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay">
                            <Binding.ValidationRules>
                                <ExceptionValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <TextBlock Style="{StaticResource Th.DialogSectionTitle}" Margin="0,0,0,2">DataType*</TextBlock>
                <ComboBox
                      SelectedItem="{Binding TpData, Mode=TwoWay}"
                      ItemsSource="{Binding Source={StaticResource TypeDataProvider}}" />

                <TextBlock Style="{StaticResource Th.DialogSectionTitle}" Margin="0,0,0,2">Bytes Order</TextBlock>
                <ComboBox SelectedItem="{Binding BtOrder, Mode=TwoWay}"
                      ItemsSource="{Binding Source={StaticResource BytesOrderProvider}}" />

                <TextBlock Style="{StaticResource Th.DialogSectionTitle}" Margin="0,0,0,2">Data Area*</TextBlock>
                <ComboBox ItemsSource="{Binding MemArList}"
                           SelectedItem="{Binding SelArea, Mode=TwoWay}" SelectedIndex="0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name, Mode=TwoWay}" />
                                <TextBlock Text=" [" />
                                <TextBlock Text="{Binding AdresSize, Mode=TwoWay}" />
                                <TextBlock Text="]" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Grid Margin="0,2,0,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Style="{StaticResource Th.DialogSectionTitle}" Margin="0,0,0,2">DB</TextBlock>
                    <TextBox Grid.Column="0" Grid.Row="1" Text="{Binding DbAdress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding DbBlockAct,Mode=TwoWay}" />

                    <TextBlock Grid.Column="1" Grid.Row="0" Style="{StaticResource Th.DialogSectionTitle}" Margin="0,0,0,2">Address</TextBlock>
                    <TextBox Grid.Column="1" Grid.Row="1" Text="{Binding Adress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Column="2" Grid.Row="0" Style="{StaticResource Th.DialogSectionTitle}" Margin="0,0,0,2">Offset [bit/byte]</TextBlock>
                    <ComboBox Grid.Column="2" Grid.Row="1"
                           IsEnabled="{Binding ScAdreList.Count}"
                           SelectedItem="{Binding SecAdress}"
                           ItemsSource="{Binding ScAdreList}" />
                </Grid>

                <TextBlock Style="{StaticResource Th.DialogSectionTitle}" Margin="0,0,0,2">Description</TextBlock>
                <TextBox Style="{StaticResource Th.DialogMultilineTextBox}" Height="70" Text="{Binding Desc}" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="{StaticResource Th.SurfaceBrush}"
                BorderBrush="{StaticResource Th.BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <StackPanel Style="{StaticResource Th.DialogBottomActionsPanel}" Margin="0">
                <Button Style="{StaticResource Th.AddTagSaveButton}" Click="Button_Save_Click" Content="Save" />
                <Button Style="{StaticResource Th.DialogBottomActionButton}" Click="Button_Close_Click">Close</Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>