<Window x:Class="FenixWPF.AddTag"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:PrCon="clr-namespace:ProjectDataLib;assembly=ProjectDataLib"
        xmlns:local="clr-namespace:FenixWPF"
        mc:Ignorable="d"
        Title="Add Tag" Height="530" Width="360"
                   WindowStartupLocation="CenterOwner"
                   >

    <Window.Resources>

        <ObjectDataProvider x:Key="TypeDataProvider" MethodName="GetValues"  ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="PrCon:TypeData" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="BytesOrderProvider" MethodName="GetValues"  ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="PrCon:BytesOrder" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="14">
            <Image Width="26" Height="26" Margin="0,0,0,10" Source="pack://application:,,,/TreeImage/Tag.ico" HorizontalAlignment="Left" />

            <TextBlock Margin="0,0,0,2" FontWeight="SemiBold">Add Range</TextBlock>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10*" />
                </Grid.ColumnDefinitions>

                <CheckBox IsChecked="{Binding RangeAct}" Name="chbAddRange" Margin="0,5,0,0" />
                <TextBox
                                Grid.Column="1"
                                Name="tbRangeCount"
                                Text="{Binding Range, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding ElementName=chbAddRange,Path=IsChecked}" />
            </Grid>

            <TextBlock Margin="0,0,0,2" FontWeight="SemiBold">Tag Name*</TextBlock>
            <TextBox Name="tbName">
                <TextBox.Text>
                    <Binding Path="TagName" UpdateSourceTrigger="PropertyChanged" Mode="TwoWay">
                        <Binding.ValidationRules>
                            <ExceptionValidationRule />
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>

            <TextBlock Margin="0,0,0,2" FontWeight="SemiBold">DataType*</TextBlock>
            <ComboBox
                  SelectedItem="{Binding TpData, Mode=TwoWay}"
                  ItemsSource="{Binding Source={StaticResource TypeDataProvider}}" />

            <TextBlock Margin="0,0,0,2" FontWeight="SemiBold">Bytes Order</TextBlock>
            <ComboBox SelectedItem="{Binding BtOrder, Mode=TwoWay}"
                  ItemsSource="{Binding Source={StaticResource BytesOrderProvider}}" />

            <TextBlock Margin="0,0,0,2" Grid.Column="0" Grid.Row="0" FontWeight="SemiBold">Data Area*</TextBlock>
            <ComboBox Grid.Column="0" Grid.Row="1"
                   ItemsSource="{Binding MemArList}"
                   SelectedItem="{Binding SelArea, Mode=TwoWay}" SelectedIndex="0">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name, Mode=TwoWay}" />
                            <TextBlock Text=" [" />
                            <TextBlock Text="{Binding AdresSize, Mode=TwoWay}" />
                            <TextBlock Text="]" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Grid Margin="0,2,0,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Grid.Row="0" FontWeight="SemiBold">DB</TextBlock>
                <TextBox Grid.Column="0" Grid.Row="1" Text="{Binding DbAdress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding DbBlockAct,Mode=TwoWay}" />

                <TextBlock Grid.Column="1" Grid.Row="0" FontWeight="SemiBold">Address</TextBlock>
                <TextBox Grid.Column="1" Grid.Row="1" Text="{Binding Adress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="2" Grid.Row="0" FontWeight="SemiBold">Offset [bit/byte]</TextBlock>
                <ComboBox  Grid.Column="2" Grid.Row="1"
                       IsEnabled="{Binding ScAdreList.Count}"
                       SelectedItem="{Binding SecAdress}"
                       ItemsSource="{Binding ScAdreList}" />
            </Grid>

            <TextBlock Margin="0,0,0,2" FontWeight="SemiBold">Description</TextBlock>
            <TextBox AcceptsReturn="True" Height="70" Text="{Binding Desc}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Margin="0,0,6,0" MinWidth="80" Click="Button_Save_Click" Content="Save">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="IsEnabled" Value="True" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Path=(Validation.HasError), ElementName=tbName}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="IsEnabled" Value="False" />
                                </MultiDataTrigger>

                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ElementName=tbName,Path=Text.Length}" Value="0" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="IsEnabled" Value="False" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button MinWidth="80" Click="Button_Close_Click">Close</Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>