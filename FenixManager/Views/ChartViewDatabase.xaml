<UserControl x:Class="FenixWPF.ChartViewDatabase"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:local="clr-namespace:FenixWPF"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{StaticResource Th.SurfaceBrush}">

    <UserControl.Resources>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="ToolbarLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="ToolbarTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <Style x:Key="ToolbarDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="12" Background="{StaticResource Th.SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Chart Filters" Padding="12,10">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" ItemHeight="30">
                <TextBlock Text="Y-Axis Min:" Style="{StaticResource ToolbarLabelStyle}" />
                <TextBox Text="{Binding YAxisMinimum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110" Style="{StaticResource ToolbarTextBoxStyle}" />

                <TextBlock Text="Y-Axis Max:" Style="{StaticResource ToolbarLabelStyle}" />
                <TextBox Text="{Binding YAxisMaximum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110" Style="{StaticResource ToolbarTextBoxStyle}" />

                <CheckBox x:Name="DisableFormCheckBox" Content="Block Time Filter" Margin="8,0,16,0" VerticalAlignment="Center" />

                <TextBlock Text="From:" Style="{StaticResource ToolbarLabelStyle}" />
                <DatePicker x:Name="FromDateCtrl"
                            Width="160"
                            Style="{StaticResource ToolbarDatePickerStyle}"
                            SelectedDate="{Binding FromDate, Mode=TwoWay}"
                            IsEnabled="{Binding IsChecked, ElementName=DisableFormCheckBox, Converter={StaticResource InverseBooleanConverter}}" />

                <TextBlock Text="To:" Style="{StaticResource ToolbarLabelStyle}" />
                <DatePicker x:Name="ToDateCtrl"
                            Width="160"
                            Style="{StaticResource ToolbarDatePickerStyle}"
                            SelectedDate="{Binding ToDate, Mode=TwoWay}"
                            IsEnabled="{Binding IsChecked, ElementName=DisableFormCheckBox, Converter={StaticResource InverseBooleanConverter}}" />

                <TextBlock Text="Last:" Style="{StaticResource ToolbarLabelStyle}" />
                <ComboBox x:Name="TimeIntervalComboBox"
                          Width="100"
                          Style="{StaticResource ToolbarComboBoxStyle}"
                          ItemsSource="{Binding TimeIntervals}"
                          SelectedItem="{Binding SelectedInterval, Mode=TwoWay}"
                          IsEnabled="{Binding IsChecked, ElementName=DisableFormCheckBox, Converter={StaticResource InverseBooleanConverter}}" />

                <Button Content="Refresh" Style="{StaticResource ToolbarButtonStyle}" Click="ShowAllButton_Click" />
            </WrapPanel>
        </GroupBox>

        <oxy:PlotView Grid.Row="2"
                      x:Name="View"
                      Controller="{Binding PlotController}"
                      Background="{StaticResource Th.SurfaceBrush}"
                      Margin="0,0,0,2" />

        <TextBlock Grid.Row="3" Margin="2,8,2,0" Text="{Binding InteractionDescription}" Foreground="{StaticResource Th.TextSecBrush}" />

        <ProgressBar Grid.Row="2"
                     IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     Width="220"
                     Height="24" />
    </Grid>
</UserControl>