<Window x:Class="FenixWPF.CheckVersion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FenixWPF"
        mc:Ignorable="d"
        Title="Check Version" Height="220" Width="420"
                   WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Margin="0,0,10,8" FontWeight="SemiBold" Grid.Row="0" Grid.Column="0" Text="Server Version" />
            <TextBlock Margin="0,0,0,8" Grid.Row="0" Grid.Column="1" Text="{Binding SerVer}" />

            <TextBlock Margin="0,0,10,8" FontWeight="SemiBold" Grid.Row="1" Grid.Column="0" Text="Installed Version" />
            <TextBlock Margin="0,0,0,8" Grid.Row="1" Grid.Column="1" Text="{Binding InsVer}" />

            <TextBlock Margin="0,0,10,8" FontWeight="SemiBold" Grid.Row="2" Grid.Column="0" Text="Status" />
            <TextBlock Margin="0,0,0,8" Grid.Row="2" Grid.Column="1" Text="{Binding Status}" />
        </Grid>

        <ProgressBar Grid.Row="1" Name="pBar" Value="{Binding ProgressValue}" Minimum="0" Maximum="100" Height="22" Margin="0,0,0,6" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button MinWidth="90" Content="Update" Margin="0,0,6,0" Click="Button_Update_Click" IsEnabled="{Binding Update}" />
            <Button MinWidth="90" Content="Close" Click="Button_Close_Click" />
        </StackPanel>
    </Grid>
</Window>