<Window  x:Class="FenixWPF.AddConnection"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pr="clr-namespace:ProjectDataLib;assembly=ProjectDataLib"
        xmlns:local="clr-namespace:FenixWPF"
        mc:Ignorable="d"
        Title="Add Connection" Height="470" Width="320" WindowStartupLocation="CenterScreen">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button MinWidth="80" IsEnabled="{Binding ElementName=TbConnName, Path=Text.Length}" Click="Button_Save_Click" Content="OK" Margin="0,0,6,0" />
            <Button MinWidth="80" Click="Button_Close_Click" Content="Close" />
        </StackPanel>

        <StackPanel>
            <Image Width="26" Height="26" Margin="0,0,0,10" Source="pack://application:,,,/TreeImage/Connection.png" HorizontalAlignment="Left" />

            <TextBlock FontWeight="SemiBold" Text="Connection Name" />
            <TextBox Name="TbConnName" Text="{Binding connectionName }" />

            <TextBlock FontWeight="SemiBold" Text="Driver Name" />
            <ComboBox x:Name="CbDrivers" SelectionChanged="CbDrivers_SelectionChanged" />

            <local:PropertiesGridManager Margin="0,4,0,0" x:Name="PgDrvProps" Height="220" />
        </StackPanel>
    </DockPanel>
</Window>