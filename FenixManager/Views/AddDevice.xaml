<Window  x:Class="FenixWPF.AddDevice"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FenixWPF"
        mc:Ignorable="d"
        Title="Add Device" Height="320" Width="320" WindowStartupLocation="CenterScreen">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button MinWidth="80" IsEnabled="{Binding ElementName=TbName,Path=Text.Length}" Click="Button_Ok_Click" Content="OK" Margin="0,0,6,0" />
            <Button MinWidth="80" Click="Button_Close_Click" Content="Close" />
        </StackPanel>

        <StackPanel>
            <Image Width="26" Height="26" Margin="0,0,0,10" Source="pack://application:,,,/TreeImage/Device.ico" HorizontalAlignment="Left" />

            <TextBlock FontWeight="SemiBold" Text="Name" />
            <TextBox Name="TbName" Text="{Binding name}" />

            <TextBlock FontWeight="SemiBold" Text="Device Address" />
            <TextBox Name="TbAdress" Text="{Binding adress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
    </DockPanel>
</Window>