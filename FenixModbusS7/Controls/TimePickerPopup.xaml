<UserControl x:Class="Fenix.TimePickerPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="190" d:DesignHeight="160">
    <UserControl.Resources>
        <Style x:Key="SpinBtn" TargetType="Button">
            <Setter Property="Width"          Value="40" />
            <Setter Property="Height"         Value="22" />
            <Setter Property="Padding"        Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background"     Value="Transparent" />
            <Setter Property="Foreground"     Value="{StaticResource Th.TextSecBrush}" />
            <Setter Property="FontSize"       Value="9" />
            <Setter Property="Focusable"      Value="False" />
            <Setter Property="Cursor"         Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4"
                                Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Th.HoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource Th.AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Th.SelBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource Th.SurfaceBrush}"
            BorderBrush="{StaticResource Th.BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12"
            Effect="{StaticResource Th.ShadowEffect}">
        <StackPanel>

            <!-- Column labels -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="40" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Hour" HorizontalAlignment="Center"
                           FontSize="{StaticResource Th.FontSm}" Foreground="{StaticResource Th.TextSecBrush}" />
                <TextBlock Grid.Column="2" Text="Min"  HorizontalAlignment="Center"
                           FontSize="{StaticResource Th.FontSm}" Foreground="{StaticResource Th.TextSecBrush}" />
                <TextBlock Grid.Column="4" Text="Sec"  HorizontalAlignment="Center"
                           FontSize="{StaticResource Th.FontSm}" Foreground="{StaticResource Th.TextSecBrush}" />
            </Grid>

            <!-- Spinners -->
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="40" />
                </Grid.ColumnDefinitions>

                <!-- Hour -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Background="Transparent"
                            MouseWheel="Hour_MouseWheel">
                    <Button Style="{StaticResource SpinBtn}" Content="▲" Click="HourUp_Click" />
                    <TextBlock x:Name="HourDisplay" Text="00" HorizontalAlignment="Center"
                               FontSize="20" FontWeight="Medium"
                               Foreground="{StaticResource Th.TextBrush}" Margin="0,4" />
                    <Button Style="{StaticResource SpinBtn}" Content="▼" Click="HourDown_Click" />
                </StackPanel>

                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource Th.TextSecBrush}" Margin="0,4,0,0" />

                <!-- Minute -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center" Background="Transparent"
                            MouseWheel="Min_MouseWheel">
                    <Button Style="{StaticResource SpinBtn}" Content="▲" Click="MinUp_Click" />
                    <TextBlock x:Name="MinDisplay" Text="00" HorizontalAlignment="Center"
                               FontSize="20" FontWeight="Medium"
                               Foreground="{StaticResource Th.TextBrush}" Margin="0,4" />
                    <Button Style="{StaticResource SpinBtn}" Content="▼" Click="MinDown_Click" />
                </StackPanel>

                <TextBlock Grid.Column="3" Text=":" VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource Th.TextSecBrush}" Margin="0,4,0,0" />

                <!-- Second -->
                <StackPanel Grid.Column="4" HorizontalAlignment="Center" Background="Transparent"
                            MouseWheel="Sec_MouseWheel">
                    <Button Style="{StaticResource SpinBtn}" Content="▲" Click="SecUp_Click" />
                    <TextBlock x:Name="SecDisplay" Text="00" HorizontalAlignment="Center"
                               FontSize="20" FontWeight="Medium"
                               Foreground="{StaticResource Th.TextBrush}" Margin="0,4" />
                    <Button Style="{StaticResource SpinBtn}" Content="▼" Click="SecDown_Click" />
                </StackPanel>
            </Grid>

            <!-- OK -->
            <Button Content="OK"
                    Style="{StaticResource Th.DialogBottomPrimaryActionButton}"
                    HorizontalAlignment="Stretch"
                    MinWidth="0"
                    Height="28"
                    Margin="0,12,0,0"
                    Click="OK_Click" />
        </StackPanel>
    </Border>
</UserControl>
