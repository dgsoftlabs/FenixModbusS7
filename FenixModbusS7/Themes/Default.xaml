<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:local="clr-namespace:Fenix">

    <!-- PALETTE: Stone neutrals + Violet accent (Linear / Vercel / shadcn/ui) -->

    <!-- Background layers -->
    <Color x:Key="Th.BgColor">#FFF8F8F9</Color>
    <Color x:Key="Th.SurfaceColor">#FFFFFFFF</Color>
    <Color x:Key="Th.Surface2Color">#FFF1F0F3</Color>

    <!-- Borders -->
    <Color x:Key="Th.BorderColor">#FFE4E2E9</Color>

    <!-- Text -->
    <Color x:Key="Th.TextColor">#FF18171C</Color>
    <Color x:Key="Th.TextSecColor">#FF706E7B</Color>

    <!-- Accent: violet-600 / violet-700 -->
    <Color x:Key="Th.AccentColor">#FF7C3AED</Color>
    <Color x:Key="Th.AccentHoverColor">#FF6D28D9</Color>
    <Color x:Key="Th.AccentFgColor">#FFFFFFFF</Color>

    <!-- Interactive states -->
    <Color x:Key="Th.HoverColor">#FFF3F2F5</Color>
    <Color x:Key="Th.SelColor">#FFEDE9FF</Color>

    <!-- FONT SIZES -->

    <sys:Double x:Key="Th.FontXs">10</sys:Double>
    <sys:Double x:Key="Th.FontSm">11</sys:Double>
    <sys:Double x:Key="Th.FontMd">12</sys:Double>
    <sys:Double x:Key="Th.FontLg">14</sys:Double>
    <sys:Double x:Key="Th.FontXl">18</sys:Double>
    <sys:Double x:Key="Th.FontXxl">24</sys:Double>

    <!-- EFFECTS -->
    <DropShadowEffect x:Key="Th.ShadowEffect"
                      BlurRadius="12"
                      ShadowDepth="2"
                      Direction="270"
                      Color="#22000000"
                      Opacity="0.5" />

    <!-- BRUSHES -->

    <SolidColorBrush x:Key="Th.BgBrush"         Color="{StaticResource Th.BgColor}" />
    <SolidColorBrush x:Key="Th.SurfaceBrush"    Color="{StaticResource Th.SurfaceColor}" />
    <SolidColorBrush x:Key="Th.Surface2Brush"   Color="{StaticResource Th.Surface2Color}" />
    <SolidColorBrush x:Key="Th.BorderBrush"     Color="{StaticResource Th.BorderColor}" />
    <SolidColorBrush x:Key="Th.TextBrush"       Color="{StaticResource Th.TextColor}" />
    <SolidColorBrush x:Key="Th.TextSecBrush"    Color="{StaticResource Th.TextSecColor}" />
    <SolidColorBrush x:Key="Th.AccentBrush"     Color="{StaticResource Th.AccentColor}" />
    <SolidColorBrush x:Key="Th.HoverBrush"      Color="{StaticResource Th.HoverColor}" />
    <SolidColorBrush x:Key="Th.SelBrush"        Color="{StaticResource Th.SelColor}" />

    <local:ColorConverter x:Key="Th.CommunicationRowColorConverter" />
    <local:FrameTooltipConverter x:Key="Th.FrameTooltipConverter" />

    <Style x:Key="Th.CommunicationRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
        <Setter Property="Background" Value="{Binding Converter={StaticResource Th.CommunicationRowColorConverter}}" />
    </Style>

    <Style x:Key="Th.CommunicationFrameCellText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="ToolTipService.ShowDuration" Value="120000" />
        <Setter Property="ToolTip">
            <Setter.Value>
                <ToolTip MaxWidth="900"
                         Background="{StaticResource Th.SurfaceBrush}"
                         BorderBrush="{StaticResource Th.BorderBrush}"
                         Foreground="{StaticResource Th.TextBrush}">
                    <TextBlock TextWrapping="Wrap"
                               FontFamily="Consolas"
                               FontSize="{StaticResource Th.FontSm}">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource Th.FrameTooltipConverter}">
                                <Binding Path="Sender" />
                                <Binding Path="Dane" />
                                <Binding Path="Info" />
                                <Binding Path="Type" />
                                <Binding Path="Czas" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </ToolTip>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- IMPLICIT: TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background"                  Value="{StaticResource Th.SurfaceBrush}" />
        <Setter Property="Foreground"                  Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderBrush"                 Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="BorderThickness"             Value="1" />
        <Setter Property="Padding"                     Value="6,4" />
        <Setter Property="FontSize"                    Value="{StaticResource Th.FontMd}" />
        <Setter Property="MinHeight"                   Value="28" />
        <Setter Property="VerticalContentAlignment"    Value="Center" />
        <Setter Property="FocusVisualStyle"            Value="{x:Null}" />
        <Setter Property="Margin"                      Value="0,0,0,6" />
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource Th.AccentBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- IMPLICIT: ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"               Value="{StaticResource Th.SurfaceBrush}" />
        <Setter Property="Foreground"               Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderBrush"              Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="BorderThickness"          Value="1" />
        <Setter Property="Padding"                  Value="6,4" />
        <Setter Property="FontSize"                 Value="{StaticResource Th.FontMd}" />
        <Setter Property="MinHeight"                Value="28" />
        <Setter Property="FocusVisualStyle"         Value="{x:Null}" />
        <Setter Property="Margin"                   Value="0,0,0,6" />
    </Style>

    <!-- IMPLICIT: Button -->
    <Style TargetType="Button">
        <Setter Property="Background"       Value="{StaticResource Th.Surface2Brush}" />
        <Setter Property="Foreground"       Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderBrush"      Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="BorderThickness"  Value="1" />
        <Setter Property="Padding"          Value="12,5" />
        <Setter Property="FontSize"         Value="{StaticResource Th.FontMd}" />
        <Setter Property="MinHeight"        Value="28" />
        <Setter Property="Cursor"           Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Th.HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Th.SelBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DIALOG: root containers -->
    <Style x:Key="Th.DialogRootGrid" TargetType="Grid">
        <Setter Property="Background" Value="{StaticResource Th.SurfaceBrush}" />
        <Setter Property="Margin"     Value="16" />
    </Style>

    <Style x:Key="Th.DialogRootDockPanel" TargetType="DockPanel">
        <Setter Property="Background"    Value="{StaticResource Th.SurfaceBrush}" />
        <Setter Property="LastChildFill" Value="True" />
        <Setter Property="Margin"        Value="16" />
    </Style>

    <!-- DIALOG: header icon -->
    <Style x:Key="Th.DialogHeaderIcon" TargetType="Image">
        <Setter Property="Width"               Value="36" />
        <Setter Property="Height"              Value="36" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin"              Value="0,0,0,12" />
    </Style>

    <!-- DIALOG: section title above inputs -->
    <Style x:Key="Th.DialogSectionTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Th.TextSecBrush}" />
        <Setter Property="FontSize"   Value="{StaticResource Th.FontSm}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin"     Value="0,6,0,2" />
    </Style>

    <!-- DIALOG: plain label -->
    <Style x:Key="Th.DialogLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Th.TextSecBrush}" />
        <Setter Property="FontSize"   Value="{StaticResource Th.FontSm}" />
        <Setter Property="Margin"     Value="0,4,0,2" />
    </Style>

    <!-- DIALOG: multiline TextBox -->
    <Style x:Key="Th.DialogMultilineTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="AcceptsReturn"               Value="True" />
        <Setter Property="TextWrapping"                Value="Wrap" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalContentAlignment"    Value="Top" />
    </Style>

    <!-- DIALOG: bottom actions panel -->
    <Style x:Key="Th.DialogBottomActionsPanel" TargetType="StackPanel">
        <Setter Property="Orientation"         Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Margin"              Value="0,10,0,0" />
    </Style>

    <!-- DIALOG: secondary button -->
    <Style x:Key="Th.DialogBottomActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="MinWidth" Value="80" />
        <Setter Property="Margin"   Value="6,0,0,0" />
    </Style>

    <!-- DIALOG: primary (accent) button -->
    <Style x:Key="Th.DialogBottomPrimaryActionButton" TargetType="Button">
        <Setter Property="Background"       Value="{StaticResource Th.AccentBrush}" />
        <Setter Property="Foreground"       Value="White" />
        <Setter Property="BorderBrush"      Value="{StaticResource Th.AccentBrush}" />
        <Setter Property="BorderThickness"  Value="1" />
        <Setter Property="Padding"          Value="12,5" />
        <Setter Property="FontSize"         Value="{StaticResource Th.FontMd}" />
        <Setter Property="MinHeight"        Value="28" />
        <Setter Property="MinWidth"         Value="80" />
        <Setter Property="Cursor"           Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource Th.AccentHoverColor}" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- AddTag save button (alias for primary) -->
    <Style x:Key="Th.AddTagSaveButton" TargetType="Button" BasedOn="{StaticResource Th.DialogBottomPrimaryActionButton}" />

    <!-- IMPLICIT: ToolBar (removes system gradient, applies theme background) -->
    <Style TargetType="ToolBar">
        <Setter Property="Background"      Value="{StaticResource Th.SurfaceBrush}" />
        <Setter Property="Foreground"      Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderBrush"     Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="ToolBar.Band"    Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolBar">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="4,2">
                        <ToolBarPanel IsItemsHost="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- IMPLICIT: ToolBarTray -->
    <Style TargetType="ToolBarTray">
        <Setter Property="Background" Value="{StaticResource Th.SurfaceBrush}" />
    </Style>

    <!-- IMPLICIT: GroupBox -->
    <Style TargetType="GroupBox">
        <Setter Property="Background"      Value="{StaticResource Th.SurfaceBrush}" />
        <Setter Property="BorderBrush"     Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"         Value="8,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{StaticResource Th.Surface2Brush}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="4,4,0,0"
                                Padding="10,6">
                            <ContentPresenter ContentSource="Header"
                                              TextBlock.Foreground="{StaticResource Th.TextBrush}"
                                              TextBlock.FontWeight="SemiBold"
                                              TextBlock.FontSize="{StaticResource Th.FontSm}" />
                        </Border>
                        <Border Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,0,1,1"
                                CornerRadius="0,0,4,4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- IMPLICIT: ProgressBar -->
    <Style TargetType="ProgressBar">
        <Setter Property="Foreground"      Value="{StaticResource Th.AccentBrush}" />
        <Setter Property="Background"      Value="{StaticResource Th.Surface2Brush}" />
        <Setter Property="BorderBrush"     Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Height"          Value="4" />
    </Style>

    <!-- TREE: expander chevron toggle -->
    <Style x:Key="Th.TreeExpanderToggle" TargetType="ToggleButton">
        <Setter Property="Focusable"   Value="False" />
        <Setter Property="Width"       Value="16" />
        <Setter Property="Height"      Value="16" />
        <Setter Property="Cursor"      Value="Arrow" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent" Width="16" Height="16">
                        <Path x:Name="Arrow"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stroke="{StaticResource Th.TextSecBrush}"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              Data="M 5 7 L 8 10 L 11 7" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="Arrow" Property="Data" Value="M 7 5 L 10 8 L 7 11" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TREE: TreeViewItem with clean hover/selection ControlTemplate -->
    <Style x:Key="Th.TreeViewItem" TargetType="TreeViewItem">
        <Setter Property="Foreground"       Value="{StaticResource Th.TextBrush}" />
        <Setter Property="FontSize"         Value="{StaticResource Th.FontMd}" />
        <Setter Property="Padding"          Value="2,2" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <Border x:Name="HeaderBd"
                                Grid.Row="0"
                                Background="Transparent"
                                CornerRadius="4"
                                Margin="1,1,4,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <ToggleButton Grid.Column="0"
                                              x:Name="Expander"
                                              Style="{StaticResource Th.TreeExpanderToggle}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press" />
                                <ContentPresenter Grid.Column="1"
                                                  x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Grid>
                        </Border>

                        <ItemsPresenter x:Name="ItemsHost"
                                        Grid.Row="1"
                                        Margin="16,0,0,0" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBd" Property="Background" Value="{StaticResource Th.HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="HeaderBd" Property="Background" Value="{StaticResource Th.SelBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected"         Value="True" />
                                <Condition Property="IsSelectionActive"  Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="HeaderBd" Property="Background" Value="{StaticResource Th.SelBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- IMPLICIT: DatePickerTextBox -->
    <Style TargetType="DatePickerTextBox">
        <Setter Property="Background"     Value="Transparent" />
        <Setter Property="Foreground"     Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="SelectionBrush" Value="{StaticResource Th.AccentBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePickerTextBox">
                    <Grid>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="WatermarkStates">
                                <VisualState x:Name="Unwatermarked" />
                                <VisualState x:Name="Watermarked">
                                    <Storyboard>
                                        <DoubleAnimation Duration="0"
                                                         Storyboard.TargetName="PART_ContentHost"
                                                         To="0"
                                                         Storyboard.TargetProperty="Opacity" />
                                        <DoubleAnimation Duration="0"
                                                         Storyboard.TargetName="PART_Watermark"
                                                         To="1"
                                                         Storyboard.TargetProperty="Opacity" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <ContentControl x:Name="PART_Watermark"
                                        Opacity="0"
                                        Focusable="False"
                                        IsHitTestVisible="False"
                                        Foreground="{StaticResource Th.TextSecBrush}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Margin="2,0" />
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="Center"
                                      Background="Transparent"
                                      Opacity="0" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- IMPLICIT: CalendarDayButton -->
    <Style TargetType="CalendarDayButton">
        <Setter Property="Width"              Value="30" />
        <Setter Property="Height"             Value="26" />
        <Setter Property="Foreground"         Value="{StaticResource Th.TextBrush}" />
        <Setter Property="FontSize"           Value="{StaticResource Th.FontSm}" />
        <Setter Property="FocusVisualStyle"   Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarDayButton">
                    <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource Th.HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource Th.AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource Th.AccentBrush}" />
                            <Setter TargetName="bg" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Th.TextSecBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CalendarButton">
        <Setter Property="Width"            Value="60" />
        <Setter Property="Height"           Value="28" />
        <Setter Property="Foreground"       Value="{StaticResource Th.TextBrush}" />
        <Setter Property="FontSize"         Value="{StaticResource Th.FontSm}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarButton">
                    <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource Th.HoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CalendarItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarItem">
                    <Border Background="{StaticResource Th.SurfaceBrush}"
                            BorderBrush="{StaticResource Th.BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8">
                        <StackPanel>
                            <!-- Header: prev / title / next -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="28" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PART_PreviousButton"
                                        Grid.Column="0"
                                        Padding="0"
                                        MinHeight="0"
                                        Height="26" Width="26"
                                        Content="&lt;"
                                        FontSize="{StaticResource Th.FontLg}"
                                        ToolTip="Previous" />
                                <Button x:Name="PART_HeaderButton"
                                        Grid.Column="1"
                                        Padding="0"
                                        MinHeight="0"
                                        Height="26"
                                        FontWeight="SemiBold"
                                        FontSize="{StaticResource Th.FontSm}" />
                                <Button x:Name="PART_NextButton"
                                        Grid.Column="2"
                                        Padding="0"
                                        MinHeight="0"
                                        Height="26" Width="26"
                                        Content="&gt;"
                                        FontSize="{StaticResource Th.FontLg}"
                                        ToolTip="Next" />
                            </Grid>

                            <!-- Day-names row -->
                            <Grid x:Name="PART_DayTitleTemplate" />

                            <!-- Month grid -->
                            <Grid x:Name="PART_MonthView"  />
                            <Grid x:Name="PART_YearView" Visibility="Hidden" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Calendar">
        <Setter Property="Background"   Value="{StaticResource Th.SurfaceBrush}" />
        <Setter Property="Foreground"   Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderBrush"  Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize"     Value="{StaticResource Th.FontSm}" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="Background"          Value="{StaticResource Th.SurfaceBrush}" />
        <Setter Property="Foreground"          Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderBrush"         Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="BorderThickness"     Value="1" />
        <Setter Property="FontSize"            Value="{StaticResource Th.FontMd}" />
        <Setter Property="MinHeight"           Value="28" />
        <Setter Property="Padding"             Value="0" />
        <Setter Property="FocusVisualStyle"    Value="{x:Null}" />
        <Setter Property="SelectedDateFormat"  Value="Short" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePicker">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            MinHeight="{TemplateBinding MinHeight}"
                            ClipToBounds="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="30" />
                            </Grid.ColumnDefinitions>

                            <!-- PART_TextBox hidden - keeps DatePicker internals working, display handled by TextBlock below -->
                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               Opacity="0"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center" />

                            <!-- Visible date / watermark display -->
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"
                                       FontSize="{StaticResource Th.FontMd}"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding SelectedDate, RelativeSource={RelativeSource AncestorType=DatePicker}, StringFormat=dd.MM.yyyy}" />
                                        <Setter Property="Foreground" Value="{StaticResource Th.TextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedDate, RelativeSource={RelativeSource AncestorType=DatePicker}}" Value="{x:Null}">
                                                <Setter Property="Text"       Value="dd.MM.yyyy" />
                                                <Setter Property="Foreground" Value="{StaticResource Th.TextSecBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Padding="0"
                                    MinHeight="0"
                                    Width="28"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Focusable="False"
                                    ToolTip="Open calendar">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE163;"
                                           FontSize="{StaticResource Th.FontMd}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=border}"
                                   StaysOpen="False" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Th.AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- IMPLICIT: Window -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource Th.BgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource Th.TextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize"   Value="{StaticResource Th.FontMd}" />
    </Style>

    <!-- IMPLICIT: Menu -->
    <Style TargetType="Menu">
        <Setter Property="Background"      Value="{StaticResource Th.SurfaceBrush}" />
        <Setter Property="Foreground"      Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush"     Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="FontSize"        Value="{StaticResource Th.FontMd}" />
        <Setter Property="Padding"         Value="4,2" />
    </Style>

    <!-- IMPLICIT: MenuItem -->
    <Style TargetType="MenuItem">
        <Setter Property="Background"       Value="Transparent" />
        <Setter Property="Foreground"       Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderThickness"  Value="0" />
        <Setter Property="Padding"          Value="10,5" />
        <Setter Property="FontSize"         Value="{StaticResource Th.FontMd}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- IMPLICIT: ContextMenu -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background"      Value="{StaticResource Th.SurfaceBrush}" />
        <Setter Property="Foreground"      Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderBrush"     Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"         Value="4" />
        <Setter Property="FontSize"        Value="{StaticResource Th.FontMd}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            Effect="{StaticResource Th.ShadowEffect}">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- IMPLICIT: Separator -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="Height"     Value="1" />
        <Setter Property="Margin"     Value="6,3" />
    </Style>

    <!-- IMPLICIT: StatusBar -->
    <Style TargetType="StatusBar">
        <Setter Property="Background"      Value="{StaticResource Th.Surface2Brush}" />
        <Setter Property="Foreground"      Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderBrush"     Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding"         Value="8,3" />
        <Setter Property="FontSize"        Value="{StaticResource Th.FontSm}" />
    </Style>

    <!-- IMPLICIT: DataGrid column header -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="{StaticResource Th.Surface2Brush}" />
        <Setter Property="Foreground"      Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderBrush"     Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding"         Value="8,0" />
        <Setter Property="FontSize"        Value="{StaticResource Th.FontSm}" />
        <Setter Property="FontWeight"      Value="SemiBold" />
        <Setter Property="Height"          Value="34" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SeparatorBrush"  Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Grid>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left" />
                                <Path x:Name="SortArrow"
                                      Grid.Column="1"
                                      Visibility="Collapsed"
                                      Stretch="None"
                                      Stroke="{StaticResource Th.AccentBrush}"
                                      StrokeThickness="1.5"
                                      Margin="4,0,2,0"
                                      VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <Thumb x:Name="PART_LeftHeaderGripper"
                               HorizontalAlignment="Left"
                               Width="4"
                               Cursor="SizeWE">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                        <Thumb x:Name="PART_RightHeaderGripper"
                               HorizontalAlignment="Right"
                               Width="4"
                               Cursor="SizeWE">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Th.HoverBrush}" />
                        </Trigger>
                        <Trigger Property="SortDirection" Value="Ascending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="Data" Value="M 5 8 L 8 5 L 11 8" />
                        </Trigger>
                        <Trigger Property="SortDirection" Value="Descending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="Data" Value="M 5 5 L 8 8 L 11 5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- IMPLICIT: DataGridRow -->
    <Style TargetType="DataGridRow">
        <Setter Property="Background"       Value="{StaticResource Th.SurfaceBrush}" />
        <Setter Property="Foreground"       Value="{StaticResource Th.TextBrush}" />
        <Setter Property="BorderBrush"      Value="{StaticResource Th.BorderBrush}" />
        <Setter Property="BorderThickness"  Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Th.HoverBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Th.SelBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- IMPLICIT: DataGridCell -->
    <Style TargetType="DataGridCell">
        <Setter Property="BorderThickness"  Value="0" />
        <Setter Property="Padding"          Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Background"       Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource Th.TextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Filter toolbar shared styles (DBChartView / DBTableView) -->
    <Style x:Key="Th.FilterLabel" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <Style x:Key="Th.FilterTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Height" Value="28" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <Style x:Key="Th.FilterDatePicker" TargetType="DatePicker" BasedOn="{StaticResource {x:Type DatePicker}}">
        <Setter Property="Height" Value="28" />
        <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <Style x:Key="Th.FilterComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="Height" Value="28" />
        <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <Style x:Key="Th.FilterButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Height" Value="28" />
        <Setter Property="MinWidth" Value="100" />
        <Setter Property="Padding" Value="12,0" />
    </Style>

</ResourceDictionary>
