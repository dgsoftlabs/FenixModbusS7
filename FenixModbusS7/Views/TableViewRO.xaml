<UserControl x:Class="Fenix.TableViewRO"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:PrCon="clr-namespace:ProjectDataLib;assembly=ProjectDataLib"
             xmlns:local="clr-namespace:Fenix"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="800">

    <UserControl.Resources>

        <ObjectDataProvider x:Key="TypeDataProvider" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="PrCon:TypeData" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <local:ValueConv        x:Key="ValueConv" />
        <local:ColorConv        x:Key="ColorConv" />
        <local:ValueMarkConv    x:Key="ValueMarkConv" />
        <local:BoolNegConverter x:Key="BoolNeg" />
        <local:BoolToVis        x:Key="BoolVis" />

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Th.Surface2Brush}" />
            <Setter Property="Foreground" Value="{StaticResource Th.TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="{StaticResource Th.BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Th.SelBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource Th.TextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="CellText">
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style TargetType="DataGridRow" x:Key="rwStyle">
            <Setter Property="MinHeight" Value="26" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Th.HoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Th.SelBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Th.AccentBrush}" />
                    <Setter Property="BorderThickness" Value="0,1" />
                </Trigger>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{StaticResource Th.Surface2Brush}" />
                </Trigger>
                <DataTrigger Binding="{Binding Path=(PrCon:ITag.GrVisibleTab)}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--Dane pomocnicze dla data grid-->
        <FrameworkElement x:Key="ProxyElement" DataContext="{Binding}" />
    </UserControl.Resources>

    <Grid>
        <DataGrid Name="View" AutoGenerateColumns="False" EnableRowVirtualization="True"
                  IsReadOnly="True"
                  RowStyle="{StaticResource rwStyle}" SelectionMode="Single"
                  AlternationCount="2"
                  ColumnHeaderHeight="30"
                  BorderThickness="1"
                  BorderBrush="{StaticResource Th.BorderBrush}"
                  Background="{StaticResource Th.SurfaceBrush}"
                  RowBackground="{StaticResource Th.SurfaceBrush}"
                  AlternatingRowBackground="{StaticResource Th.Surface2Brush}"
                  GridLinesVisibility="Horizontal">
            <DataGrid.VerticalGridLinesBrush>
                <SolidColorBrush Color="{StaticResource Th.BorderColor}" />
            </DataGrid.VerticalGridLinesBrush>
            <DataGrid.HorizontalGridLinesBrush>
                <SolidColorBrush Color="{StaticResource Th.BorderColor}" />
            </DataGrid.HorizontalGridLinesBrush>

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <CheckBox Content="Color"       IsChecked="{Binding Pr.TableConf.TvCol1,  Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                    <CheckBox Content="ChartView"   IsChecked="{Binding Pr.TableConf.TvCol2,  Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                    <CheckBox Content="Width"       IsChecked="{Binding Pr.TableConf.TvCol3,  Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                    <CheckBox Content="Tag Name"    IsChecked="{Binding Pr.TableConf.TvCol4,  Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                    <CheckBox Content="DB"          IsChecked="{Binding Pr.TableConf.TvCol5,  Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                    <CheckBox Content="Start"       IsChecked="{Binding Pr.TableConf.TvCol6,  Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                    <CheckBox Content="Bit / Byte"  IsChecked="{Binding Pr.TableConf.TvCol7,  Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                    <CheckBox Content="DataType"    IsChecked="{Binding Pr.TableConf.TvCol8,  Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                    <CheckBox Content="Memory Area" IsChecked="{Binding Pr.TableConf.TvCol9,  Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                    <CheckBox Content="Bytes Order" IsChecked="{Binding Pr.TableConf.TvCol10, Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                    <CheckBox Content="Value"       IsChecked="{Binding Pr.TableConf.TvCol11, Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                    <CheckBox Content="Description" IsChecked="{Binding Pr.TableConf.TvCol14, Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                    <CheckBox Content="Version"     IsChecked="{Binding Pr.TableConf.TvCol15, Mode=TwoWay, Converter={StaticResource BoolNeg}}" />
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>

                <!-- Color -->
                <DataGridTemplateColumn Header="Color" Width="*"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol1, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    BorderBrush="{StaticResource Th.BorderBrush}" BorderThickness="1"
                                    Background="{Binding Path=(PrCon:ITag.Clr), Converter={StaticResource ColorConv}}"
                                    ToolTip="{Binding Path=(PrCon:ITag.Clr)}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- ChartView -->
                <DataGridCheckBoxColumn Header="ChartView" Width="*" IsReadOnly="True"
                    Binding="{Binding Path=(PrCon:ITag.GrVisible), Mode=OneWay}"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol2, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}" />

                <!-- Width -->
                <DataGridTemplateColumn Header="Width" Width="*"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol3, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource CellText}" Text="{Binding Path=(PrCon:ITag.Width)}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Tag Name -->
                <DataGridTemplateColumn Header="Tag Name" Width="*"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol4, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource CellText}" Text="{Binding Path=(PrCon:ITag.Name)}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- DB -->
                <DataGridTemplateColumn Header="DB" Width="*"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol5, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource CellText}" Text="{Binding Path=(PrCon:ITag.BlockAdress)}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Start -->
                <DataGridTemplateColumn Header="Start" Width="*"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol6, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource CellText}" Text="{Binding Path=(PrCon:ITag.Adress)}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Bit / Byte -->
                <DataGridTemplateColumn Header="Bit / Byte" Width="*"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol7, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource CellText}" Text="{Binding Path=(PrCon:ITag.BitByte)}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Data Type -->
                <DataGridTemplateColumn Header="Data Type" Width="*"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol8, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource CellText}" Text="{Binding Path=(PrCon:ITag.TypeData_)}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Memory Area -->
                <DataGridTemplateColumn Header="Memory Area" Width="*"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol9, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource CellText}" Text="{Binding Path=(PrCon:ITag.AreaData)}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Bytes Order -->
                <DataGridTemplateColumn Header="Bytes Order" Width="*"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol10, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource CellText}" Text="{Binding Path=(PrCon:ITag.BytesOrder_)}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Value -->
                <DataGridTemplateColumn Header="Value" Width="*"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol11, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock x:Name="Val"
                                       Style="{StaticResource CellText}"
                                       FontWeight="SemiBold" FontSize="12" TextAlignment="Center"
                                       Background="{Binding Path=(PrCon:ITag.Value), Converter={StaticResource ValueMarkConv}}">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource ValueConv}">
                                        <Binding Path="(PrCon:ITag.Value)" />
                                        <Binding />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Description -->
                <DataGridTemplateColumn Header="Description" Width="*"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol14, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource CellText}" Text="{Binding Path=(PrCon:ITag.Description)}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Version -->
                <DataGridTemplateColumn Header="Version" Width="*"
                    Visibility="{Binding Path=DataContext.Pr.TableConf.TvCol15, Converter={StaticResource BoolVis}, Source={StaticResource ProxyElement}, Mode=TwoWay}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource CellText}" Text="{Binding Path=(PrCon:ITag.TagVersion)}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

