<Window  x:Class="Fenix.AddConnection"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pr="clr-namespace:ProjectDataLib;assembly=ProjectDataLib"
        xmlns:local="clr-namespace:Fenix"
        mc:Ignorable="d"
        Title="Add Connection" Height="470" Width="320" WindowStartupLocation="CenterOwner"
        Background="{StaticResource Th.SurfaceBrush}">
    <DockPanel Style="{StaticResource Th.DialogRootDockPanel}">
        <StackPanel DockPanel.Dock="Bottom" Style="{StaticResource Th.DialogBottomActionsPanel}">
            <Button IsEnabled="{Binding ElementName=TbConnName, Path=Text.Length}" Click="Button_Save_Click" Content="OK" Style="{StaticResource Th.DialogBottomPrimaryActionButton}" />
            <Button Click="Button_Close_Click" Content="Close" Style="{StaticResource Th.DialogBottomActionButton}" />
        </StackPanel>

        <StackPanel>
            <Image Source="pack://application:,,,/TreeImage/Connection.png" Style="{StaticResource Th.DialogHeaderIcon}" />

            <TextBlock Text="Connection Name" Style="{StaticResource Th.DialogSectionTitle}" />
            <TextBox Name="TbConnName" Text="{Binding connectionName }" />

            <TextBlock Text="Driver Name" Style="{StaticResource Th.DialogSectionTitle}" />
            <ComboBox x:Name="CbDrivers" SelectionChanged="CbDrivers_SelectionChanged" />

            <local:PropertiesGridManager x:Name="PgDrvProps" Margin="0,4,0,0" Height="220" />
        </StackPanel>
    </DockPanel>
</Window>