<Window  x:Class="Fenix.AddDevice"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fenix"
        mc:Ignorable="d"
        Title="Add Device" Height="320" Width="320" WindowStartupLocation="CenterOwner"
        Background="{StaticResource Th.SurfaceBrush}">
    <DockPanel Style="{StaticResource Th.DialogRootDockPanel}">
        <StackPanel DockPanel.Dock="Bottom" Style="{StaticResource Th.DialogBottomActionsPanel}">
            <Button IsEnabled="{Binding ElementName=TbName,Path=Text.Length}" Click="Button_Ok_Click" Content="OK" Style="{StaticResource Th.DialogBottomPrimaryActionButton}" />
            <Button Click="Button_Close_Click" Content="Close" Style="{StaticResource Th.DialogBottomActionButton}" />
        </StackPanel>

        <StackPanel>
            <Image Source="pack://application:,,,/TreeImage/Device.ico" Style="{StaticResource Th.DialogHeaderIcon}" />

            <TextBlock Text="Name" Style="{StaticResource Th.DialogSectionTitle}" />
            <TextBox Name="TbName" Text="{Binding name}" />

            <TextBlock Text="Device Address" Style="{StaticResource Th.DialogSectionTitle}" />
            <TextBox Name="TbAdress" Text="{Binding adress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
    </DockPanel>
</Window>