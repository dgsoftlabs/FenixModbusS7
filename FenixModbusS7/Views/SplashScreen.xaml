<Window x:Class="Fenix.SplashScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        Width="480" Height="280"
        Topmost="True">
    <Border CornerRadius="10" Background="#1E1E2E" BorderBrush="#3A3A5C" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
            </Grid.RowDefinitions>

            <Image Grid.Row="0" Source="pack://application:,,,/dgsoftlabs.png"
                   Stretch="Uniform"
                   Margin="40,30,40,10" />

            <TextBlock Grid.Row="1"
                       Text="FenixModbusS7"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#E0E0FF"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />

            <TextBlock Grid.Row="2" x:Name="StatusText"
                       Text="Loading..."
                       FontSize="11"
                       Foreground="#8888AA"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10" />

            <ProgressBar Grid.Row="3"
                         x:Name="ProgressBar"
                         Height="4"
                         Margin="20,0,20,12"
                         Background="#2A2A4A"
                         Foreground="#5A8AFF"
                         BorderThickness="0"
                         IsIndeterminate="True"
                         VerticalAlignment="Bottom" />
        </Grid>
    </Border>
</Window>
